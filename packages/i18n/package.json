{
  "name": "@fleethub/i18n",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./locales/es.json": "./locales/es.json",
    "./locales/ca.json": "./locales/ca.json"
  },
