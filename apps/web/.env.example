# Copy to `.env.local`. Next.js listens on port 3000 by default.

# After `npm run db:create-app-role`, use fleethub_app here so the API enforces RLS like production.
# Monorepo root `fleethub/.env` should keep user `fleethub` for `npm run db:push`, seed, etc.
DATABASE_URL="postgresql://fleethub_app:fleethub_app@localhost:5432/fleethub?schema=public"
REDIS_URL="redis://localhost:6379"

AUTH_SECRET="change-me-use-openssl-rand-base64-32-in-production"

# Public browser origin of this Next app (metadata, links). Must match the URL you open in the browser.
NEXT_PUBLIC_APP_URL="https://activex.rest"

# **Required** — Internal base URL of `@fleethub/server` (no trailing slash). Next rewrites `/api/*` here.
# On the same host as nginx: always `http://127.0.0.1:4000` (or `http://127.0.0.1:<PORT>`).
# Do NOT set this to `https://api.activex.rest` when nginx already proxies api.* to Next — that loops
# back through nginx and causes 400/431 "headers too large".
NEXT_PUBLIC_SERVER_URL="http://127.0.0.1:4000"

# HTTPS in development (e.g. Next behind nginx TLS): API `Set-Cookie` needs Secure (set on **apps/server** env).
# FORCE_COOKIE_SECURE=1

# Local only (HTTP):
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_SERVER_URL="http://127.0.0.1:4000"
