# FleetHub HTTP API (auth, future REST). Loaded after repo `fleethub/.env`.
PORT=4000
# Comma-separated browser origins allowed to call this API (CORS + credentials).
WEB_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,https://activex.rest
# Optional: parent domain for Set-Cookie when web and API use different subdomains, e.g. `.activex.rest`
# SESSION_COOKIE_DOMAIN=
# HTTPS while NODE_ENV=development: add Secure to Set-Cookie (browsers require it on https:// origins).
# FORCE_COOKIE_SECURE=1
# APP_PUBLIC_URL="http://localhost:3000"
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="FleetHub <noreply@fleethub.local>"


SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=fleethub2026@gmail.com
SMTP_PASS=udqaphuaivhflmeo
SMTP_FROM=FleetHub <fleethub2026@gmail.com>