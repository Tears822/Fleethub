{
  "name": "@fleethub/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-http-header-size=65536' tsx watch src/index.ts",
    "start": "NODE_OPTIONS='--max-http-header-size=65536' node --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fleethub/auth": "*",
    "@fleethub/db": "*",
    "@fleethub/i18n": "*",
    "@fleethub/worker": "*",
    "archiver": "^5.3.2",
    "bullmq": "^5.52.2",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.1",
    "ioredis": "^5.6.1",
    "pdfkit": "^0.18.0",
    "secure-json-parse": "^4.1.0"
  },
  "devDependencies": {
    "@types/archiver": "^5.3.4",
    "@types/node": "^22.15.18",
    "@types/pdfkit": "^0.17.6",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
