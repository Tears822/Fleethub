# Monorepo root env — copied by systemd into API/worker (EnvironmentFile).
# Copy: cp .env.example .env  then fill secrets.

# DB owner for migrations; runtime uses fleethub_app via apps/server/.env
DATABASE_URL="postgresql://fleethub:fleethub@localhost:5432/fleethub?schema=public"
REDIS_URL="redis://localhost:6379"
AUTH_SECRET="change-me-use-openssl-rand-base64-32"

# Next.js (also set in apps/web/.env.local for server components)
NEXT_PUBLIC_APP_URL="https://activex.rest"
NEXT_PUBLIC_SERVER_URL="http://127.0.0.1:4000"

# API CORS
WEB_ORIGIN="http://localhost:3000,http://127.0.0.1:3000,https://activex.rest"

# Uber Vehicle Suppliers (group account — use per-tenant org in settings or UBER_ORG_ID_*)
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
UBER_OAUTH_SCOPE="solutions.suppliers.metrics.read solutions.suppliers.reports supplier.partner.payments vehicle_suppliers.organizations.read solutions.suppliers.drivers.status.read"
UBER_TOKEN_URL="https://auth.uber.com/oauth/v2/token"
UBER_API_BASE_URL="https://api.uber.com"
UBER_SANDBOX=false
UBER_ORG_ID=
# Per-tenant overrides (recommended for group): UBER_ORG_ID_TRADE_TAXI_SL, UBER_ORG_ID_COSCULLUELA, UBER_ORG_ID_TREVINO

# FreeNow
FREENOW_CLIENT_ID=
FREENOW_CLIENT_SECRET=
FREENOW_TOKEN_URL="https://idp.live.free-now.com/keycloak/realms/company/protocol/openid-connect/token"
FREENOW_API_BASE_URL="https://api.live.free-now.com/partnerpublicgatewayservice/api"
FREENOW_PRELIVE=false
FREENOW_PUBLIC_COMPANY_ID=

# Webhooks
WEBHOOK_UBER_SIGNING_SECRET=
WEBHOOK_FREENOW_TOKEN=
WEBHOOK_REQUIRE_SIGNATURE=1
WEBHOOK_ENQUEUE_ENABLED=1
WEBHOOK_NARROW_SYNC_ENABLED=1

# SMTP (invites, alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FleetHub <noreply@example.com>"

# Worker
WORKER_MODE=fleet
WORKER_SYNC_CONCURRENCY=2
